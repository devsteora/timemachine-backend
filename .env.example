# Copy this file to .env and fill in your values.
# In production, these are injected from AWS Secrets Manager (see infra/aws/cloudformation.yml).

DATABASE_URL=postgresql://admin:password@localhost:5432/timetracker
SECRET_KEY=change-me-use-a-64-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated list of allowed CORS origins.
# For local dev: http://localhost:3000
# For production: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Optional — AI features
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional — outbound email (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
